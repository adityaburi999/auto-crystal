{
  "schemaVersion": 1,
  "id": "autocrystal",
  "version": "${version}",
  "name": "AutoCrystal – Human Pattern",
  "description": "A Fabric mod that performs auto-crystal with a sophisticated human-behaviour pattern algorithm, making actions indistinguishable from a skilled human player.",
  "authors": [
    "adityaburi999"
  ],
  "contact": {
    "homepage": "https://github.com/adityaburi999/auto-crystal",
    "sources": "https://github.com/adityaburi999/auto-crystal"
  },
  "license": "MIT",
  "icon": "assets/autocrystal/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.autocrystal.AutoCrystalMod"
    ],
    "client": [
      "com.autocrystal.AutoCrystalClient"
    ]
  },
  "mixins": [
    "autocrystal.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api": "*",
    "minecraft": "~1.21.4",
    "java": ">=21"
  }
}
